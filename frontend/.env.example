# =========================================
# Everlink Frontend — Environment Variables
# Copy this file to `.env` and fill in real values.
# =========================================

# Backend API base URL (no trailing slash)
# Local dev:        http://localhost:5000
# Render production: https://your-backend.onrender.com
VITE_API_URL=http://localhost:5000

# Where short links live — usually the same as VITE_API_URL because
# the backend hosts the /:slug redirect route.
VITE_SHORT_URL_BASE=http://localhost:5000
