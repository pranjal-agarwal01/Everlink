# =========================================
# Everlink Backend — Environment Variables
# Copy this file to `.env` and fill in real values.
# =========================================

# Runtime
NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
# Get one at https://www.mongodb.com/atlas (free tier is fine)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/everlink

# JWT signing — generate with: openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# SMTP / Gmail (App Password, NOT your account password)
# How to: Google Account → Security → 2-Step Verification → App Passwords → "Mail"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_EMAIL=youraccount@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
FROM_NAME=Everlink
FROM_EMAIL=youraccount@gmail.com

# CORS — comma-separated list of allowed frontend origins (no trailing slash)
# In production: https://your-app.vercel.app
# For Vercel previews you can add multiple: https://your-app.vercel.app,https://your-app-git-feature.vercel.app
FRONTEND_URL=http://localhost:5173
