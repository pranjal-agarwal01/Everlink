# =========================================
# Everlink Backend — Environment Variables
# Copy this file to `.env` and fill in real values.
# =========================================

# Runtime
NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
# Get one at https://www.mongodb.com/atlas (free tier is fine)
# IMPORTANT: in Atlas → Network Access, add 0.0.0.0/0 so Render can connect.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/everlink

# JWT signing — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# =========================================
# Email sending — pick ONE:
# =========================================

# Option A (RECOMMENDED for production / Render):
# Brevo HTTPS API. Render free tier blocks SMTP, so SMTP/Gmail will NOT work on Render.
# 1. Sign up at https://www.brevo.com (free, 300 emails/day)
# 2. Senders & IP → Senders → add and verify your sender email
# 3. SMTP & API → API Keys → create a v3 key, paste below
BREVO_API_KEY=
FROM_NAME=Everlink
FROM_EMAIL=your_verified_sender@example.com

# Option B (local dev only — Gmail SMTP):
# Only used if BREVO_API_KEY is empty. App Password required (not your real password).
# Google Account → Security → 2-Step Verification → App Passwords → "Mail".
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_EMAIL=
SMTP_PASSWORD=

# CORS — comma-separated list of allowed frontend origins (no trailing slash)
# In production: https://your-app.vercel.app
# For Vercel previews you can add multiple: https://your-app.vercel.app,https://your-app-git-feature.vercel.app
FRONTEND_URL=http://localhost:5173
